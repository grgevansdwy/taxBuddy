# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# real personal tax documents dropped in for local testing — never commit these
Robinhood Markets Consolidated Form 1099.pdf
# ...and any other PDF dropped at the repo root. Test fixtures belong in tests/
# and the blank IRS forms in lib/pdf/templates/, both of which stay tracked.
/*.pdf

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# model-bench eval harness (throwaway; outputs contain real tax PII)
eval/
